# Copy this file to .env and fill in values. .env is git-ignored.

# A long random string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me

# Keep True for local dev, False in production.
DEBUG=True

# Comma-separated hostnames, e.g. myblog.onrender.com (used when DEBUG=False).
ALLOWED_HOSTS=

# Comma-separated full origins for CSRF, e.g. https://myblog.onrender.com
CSRF_TRUSTED_ORIGINS=

# Leave unset to use SQLite for dev. For local Postgres, e.g.:
# DATABASE_URL=postgres://blog:blogpass@localhost:5432/blog
DATABASE_URL=

# Email (only used when DEBUG=False; dev prints emails to the console).
# Required in production: signups need email verification (mandatory).
# Example for a typical SMTP provider:
#   EMAIL_HOST=smtp.example.com
#   EMAIL_PORT=587
#   EMAIL_HOST_USER=apikey-or-username
#   EMAIL_HOST_PASSWORD=your-smtp-password
#   EMAIL_USE_TLS=True
#   DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@blogplatform.local

# (Optional) "Sign in with Google". Leave blank to hide the button — the site
# runs fine without it. Create OAuth credentials in Google Cloud Console with
# authorised redirect URI: https://<your-host>/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
